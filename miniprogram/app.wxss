page {
  background: #f3ede2;
  color: #2d2418;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

.screen {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.panel {
  background: #fffaf2;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 40rpx rgba(58, 41, 22, 0.08);
  margin-bottom: 24rpx;
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.muted {
  color: #746a5f;
}

.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #efe3ce;
  color: #725226;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.primary-btn {
  background: #0f766e;
  color: #ffffff;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.secondary-btn {
  background: #efe7d8;
  color: #594c3d;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.danger-btn {
  background: #f97316;
  color: #fff;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card,
.reminder-card,
.contact-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 28rpx rgba(30, 24, 18, 0.06);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
}

.status-pill {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #d8f0ed;
  color: #0f766e;
  font-size: 22rpx;
}

.priority-pill {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #fce6d7;
  color: #b45309;
  font-size: 22rpx;
}

.row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.empty-state {
  text-align: center;
  color: #7b7166;
  padding: 80rpx 20rpx;
}

.hero {
  background: linear-gradient(135deg, #fff7eb 0%, #edf7f3 100%);
  border-radius: 32rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #61574a;
  line-height: 1.6;
}

.field {
  margin-bottom: 24rpx;
}

.field-label {
  font-size: 24rpx;
  color: #6d6558;
  margin-bottom: 10rpx;
}

.field-input {
  background: #fff;
  border-radius: 18rpx;
  padding: 22rpx 20rpx;
  font-size: 28rpx;
  border: 2rpx solid #efe2ce;
}
